# Gemini API key (server-side, required)
GEMINI_API_KEY="your_gemini_api_key"

# Stripe API keys
STRIPE_SECRET_KEY="your_stripe_secret_key"
VITE_STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key"

# Public app URL for Stripe redirect (recommended in Vercel)
APP_URL="https://your-project.vercel.app"

# Stable auth origin used for Google auth from Vercel preview domains
VITE_AUTH_ORIGIN="https://your-production-domain.vercel.app"

# Firebase web config (client-side)
VITE_FIREBASE_API_KEY="your_firebase_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_APP_ID="1:1234567890:web:abcdef123456"
